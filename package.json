{
  "name": "finance-tracker",
  "private": true,
  "engines": {
    "node": "24.15.0",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter @acme/web dev",
    "dev:api": "pnpm --filter @acme/api dev",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:generate": "pnpm --filter @acme/api db:generate",
    "db:migrate": "pnpm --filter @acme/api db:migrate",
    "db:push": "pnpm --filter @acme/api db:push",
    "db:studio": "pnpm --filter @acme/api db:studio"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
