{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "nodenext",
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",

    /* Bundler mode */
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "sourceMap": true,

    /* Linting */
    "erasableSyntaxOnly": true
  }
}
