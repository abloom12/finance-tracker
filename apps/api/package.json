{
  "name": "api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "fastify start src/app.ts",
    "auth:generate": "pnpm dlx auth@latest generate --output ./src/drizzle/schemas/new-auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.8",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "10.3.0",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-cli": "8.0.0",
    "nodemailer": "8.0.6",
    "pg": "8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@total-typescript/ts-reset": "catalog:",
    "@types/node": "catalog:",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "tsx": "4.21.0",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config"
}
