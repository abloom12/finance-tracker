{
  "extends": "@acme/tsconfig/base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "${configDir}/.cache/tsconfig.app.tsbuildinfo",

    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["@total-typescript/ts-reset", "vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",

    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src"]
}
